# ─────────────────────────────────────────────────────────────
# .env.tunnel  —  db-tunnel.mjs 用の環境変数テンプレート
# このファイルを .env.tunnel にコピーして値を埋めてください。
# 絶対に git にコミットしないこと (.gitignore に追加すること)
# ─────────────────────────────────────────────────────────────

# AWS 設定
AWS_PROFILE=your-aws-profile
AWS_REGION=ap-northeast-1

# 踏み台 EC2 インスタンス ID (例: i-0123456789abcdef0)
BASTION_INSTANCE_ID=i-xxxxxxxxxxxxxxxxx

# Aurora PostgreSQL エンドポイント (VPC 内部ホスト名)
# RDS コンソール > クラスター > 「ライターエンドポイント」 の値
DB_HOST=your-cluster.cluster-xxxxxxxxxxxx.ap-northeast-1.rds.amazonaws.com
DB_PORT=5432

# ローカル待受ポート (psql -p で指定するポート)
LOCAL_PORT=15432
