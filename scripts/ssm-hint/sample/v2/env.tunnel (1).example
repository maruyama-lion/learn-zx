# ─────────────────────────────────────────────────────────────────────────────
# .env.tunnel  —  db-tunnel.mjs 用の環境変数テンプレート
# cp .env.tunnel.example .env.tunnel  してから値を埋めてください。
# !! 絶対に git にコミットしないこと → .gitignore に .env.tunnel を追加 !!
# ─────────────────────────────────────────────────────────────────────────────

# AWS 設定
AWS_PROFILE=your-aws-profile
AWS_REGION=ap-northeast-1

# 踏み台 EC2 インスタンス ID
BASTION_INSTANCE_ID=i-xxxxxxxxxxxxxxxxx

# Secrets Manager のシークレット名 or ARN
# RDS コンソール > クラスター > 「認証情報の管理」で確認できる値
DB_SECRET_ID=your-secret-name
# または完全 ARN: arn:aws:secretsmanager:ap-northeast-1:123456789012:secret:your-secret-name-AbCdEf

# ローカル待受ポート (psql -p で指定するポート)
LOCAL_PORT=15432
